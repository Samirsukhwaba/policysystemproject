							"source": {
								"type": "AzureSqlSource",
								"sqlReaderQuery": "select max(create_timestamp) as last_create_timestamp from dbo.agent",
								"queryTimeout": "02:00:00",
								"partitionOption": "None"
							},
							"dataset": {
								"referenceName": "sql_db_ds",
								"type": "DatasetReference",
								"parameters": {}
							}
						}
					},
					{
						"name": "Copy tables to adls",
						"type": "Copy",
						"dependsOn": [
							{
								"activity": "get the latestdate from table",
								"dependencyConditions": [
