							"source": {
								"type": "DelimitedTextSource",
								"storeSettings": {
									"type": "AzureBlobFSReadSettings",
									"recursive": true,
									"enablePartitionDiscovery": false
								},
								"formatSettings": {
									"type": "DelimitedTextReadSettings"
								}
							},
							"dataset": {
								"referenceName": "agent_hwm_csv",
								"type": "DatasetReference",
								"parameters": {}
							}
						}
					},
					{
						"name": "get the latestdate from table",
						"type": "Lookup",
